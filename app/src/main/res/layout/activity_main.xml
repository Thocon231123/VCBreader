<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#0A0A0A">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VCB Reader"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đọc to thông báo Vietcombank"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="32dp"/>

    <!-- STATUS -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Đang kiểm tra..."
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:background="#141414"
        android:padding="16dp"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="24dp"/>

    <!-- TÊN CHỦ NHÂN -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TÊN CHỦ NHÂN"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#555555"
        android:letterSpacing="0.15"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sẽ đọc: \"Thưa [tên], tài khoản VCB vừa cộng...\""
        android:textSize="12sp"
        android:textColor="#444444"
        android:layout_marginBottom="10dp"/>

    <EditText
        android:id="@+id/et_owner_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="ông chủ"
        android:textColorHint="#333333"
        android:textColor="#EEEEEE"
        android:background="#141414"
        android:padding="14dp"
        android:textSize="16sp"
        android:inputType="text"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Lưu tên"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#0A0A0A"
        android:backgroundTint="#C8A96E"
        android:layout_marginBottom="16dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E1E1E"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btn_permission"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Cấp quyền ngay"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1A1A1A"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sau khi nhấn, tìm \"VCB Reader\" trong danh sách và bật lên"
        android:textSize="12sp"
        android:textColor="#444444"
        android:layout_marginTop="8dp"
        android:gravity="center"/>

</LinearLayout>
